# Preferred production auth: Gemini on Vertex AI.
GCP_LOCATION=global
GCP_PROJECT_ID=
GOOGLE_CREDENTIALS=

# Optional local/dev fallback for the Gemini Developer API.
GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Order notification email.
# Gmail requires an app password, not the normal account password.
ORDER_EMAIL_SMTP_HOST=smtp.gmail.com
ORDER_EMAIL_SMTP_PORT=587
ORDER_EMAIL_SMTP_USER=
ORDER_EMAIL_SMTP_PASSWORD=
ORDER_EMAIL_FROM=
ORDER_EMAIL_TO=kju7859@gmail.com

# Keep unset/false in production; when true the API can accept orders without sending email.
ORDER_EMAIL_ALLOW_SKIP=0
